<div
  id="chatbot-stream"
  class="chat-stream scrollbar-chat min-h-0 min-w-0 flex-1 self-stretch overflow-y-auto"
>
  <div class="space-y-4" id="chatbot-messages">
    <div class="theme-strong mt-3 text-center text-xs first:mt-0">
      Welcome to Relay
      <br>
      <%= session["provider"] %> / <%= session["model"] %>
    </div>
    <% messages.each do |message| %>
      <%== partial("fragments/message", locals: {message:}) %>
    <% end %>
    <% if messages.empty? %>
      <div class="theme-strong px-2 text-sm leading-7" id="chatbot-empty-state">
        Ask a question, switch models, or explore the built-in tools.
      </div>
    <% end %>
    <div id="chatbot-bottom"></div>
  </div>
</div>
