<div
  id="chat-panel"
  class="flex min-h-0 min-w-0 flex-1 flex-col gap-4"
  hx-ext="ws"
  hx-swap-oob="outerHTML"
  ws-connect="/api/ws"
>
  <%== partial("fragments/stream", locals: {messages: messages || []}) %>
