  class="panel hidden w-full shrink-0 overflow-hidden lg:sticky lg:top-6 lg:flex lg:w-[24rem] lg:self-start"
>
  <div class="flex w-full flex-col">
    <div class="border-b border-stone-200/80 bg-stone-50/80 px-4 py-3">
      <div class="label">Now Playing</div>
      <div id="media-dock-title" class="mt-1 text-sm font-medium text-zinc-700">
        Waiting for a track
      </div>
    </div>
    <div
      id="media-dock-body"
      class="flex min-h-[14rem] items-center justify-center bg-zinc-950/95 p-3 text-sm text-zinc-400"
    >
      Ask for a list of songs to choose a music video
    </div>
  </div>
</aside>
