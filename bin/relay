#!/usr/bin/env ruby
# frozen_string_literal: true

def wait
  Process.wait
rescue Interrupt
  retry
end

def libexec
  File.realpath File.join(__dir__, "..", "libexec", "relay")
end

def main(argv)
  case argv[0]
  when "start", "setup", "download-models", "migrate", "bootstrap"
    Process.spawn File.join(libexec, argv[0]), *argv[1..]
    Process.wait
  else
    require_relative "../lib/relay"
    warn Relay.banner
    warn "Usage: relay [COMMAND] [OPTIONS]\n\n" \
        "Commands:\n" \
        "  setup             Setup Relay for the first time\n" \
        "  download-models   Download provider model catalogs\n" \
        "  start             Start Relay\n" \
        "  migrate           Run database migrations\n"
  end
rescue Interrupt
  wait
end

main(ARGV)
