#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "shellwords"

require_relative "../../lib/relay"

module Relay
  module CLI
    module_function

    def configure
      puts "Setting up Relay in #{Relay::HOME}..."
      FileUtils.mkdir_p(File.join(Relay::HOME, "tools"))
      FileUtils.mkdir_p(File.join(Relay::HOME, "db"))
      puts "Done. Relay is ready to start."
    end
  end
end

Relay::CLI.configure if __FILE__ == $PROGRAM_NAME
